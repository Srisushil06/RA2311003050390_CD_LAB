def infix_to_postfix(expr):
    stack = []
    output = ""

    precedence = {'+':1, '-':1, '*':2, '/':2}

    for char in expr:
        if char.isalnum():
            output += char
        elif char in precedence:
            while stack and precedence.get(stack[-1],0) >= precedence[char]:
                output += stack.pop()
            stack.append(char)

    while stack:
        output += stack.pop()

    return output

print("Postfix:", infix_to_postfix("a+b*c"))
